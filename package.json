{
  "name": "sudoku-project",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:debug": "next dev --turbo --inspect",
    "build": "next build --turbo && tsc && pnpm copy-cache-handler && pnpm strip:sourcemaps",
    "copy-cache-handler": "test -f cache-handler.ts && cp cache-handler.ts .next/cache-handler.ts || echo 'No cache handler to copy'",
    "strip:sourcemaps": "node --experimental-strip-types scripts/strip-production-sourcemaps.ts",
    "start": "next start",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "oxlint": "vp lint",
    "type-check": "tsc --noEmit",
    "quality": "vp check && pnpm type-check",
    "quality:fix": "vp check --fix && pnpm type-check",
    "test": "vp test",
    "test:ui": "vp test --ui",
    "test:pbt": "PBT_PROPERTY_TIME_LIMIT_MS=${PBT_PROPERTY_TIME_LIMIT_MS:-2500} vp test run --reporter=verbose src/**/*.pbt.test.ts",
    "test:coverage": "vp test run --coverage --reporter=verbose",
    "test:responsive": "./scripts/test-responsive.sh",
    "test:contrast": "node --experimental-strip-types scripts/validate-contrast.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "./scripts/install-playwright.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "fast-sudoku-solver": "3.0.3",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "web-vitals": "5.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.59.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "fast-check": "4.8.0",
    "happy-dom": "20.10.3",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "oxlint": "1.70.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plus": "^0.2.1",
    "vitest": "4.1.8"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead",
    "not ie 11"
  ],
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
