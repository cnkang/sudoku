{
  "name": "sudoku-project",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:debug": "next dev --turbo --inspect",
    "build": "next build --turbo && pnpm type-check && pnpm strip:sourcemaps",
    "strip:sourcemaps": "node --experimental-strip-types scripts/strip-production-sourcemaps.ts",
    "start": "next start",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "oxlint": "vp lint",
    "type-check": "node node_modules/typescript-next/bin/tsc --noEmit",
    "quality": "vp check && pnpm type-check",
    "quality:fix": "vp check --fix && pnpm type-check",
    "test": "vp test",
    "test:ui": "vp test --ui",
    "test:pbt": "PBT_PROPERTY_TIME_LIMIT_MS=${PBT_PROPERTY_TIME_LIMIT_MS:-2500} vp test run --reporter=verbose src/**/*.pbt.test.ts",
    "test:coverage": "vp test run --coverage --reporter=verbose",
    "test:responsive": "./scripts/test-responsive.sh",
    "test:contrast": "node --experimental-strip-types scripts/validate-contrast.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "./scripts/install-playwright.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "fast-sudoku-solver": "3.0.3",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "web-vitals": "5.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.59.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "fast-check": "4.9.0",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxlint": "1.74.0",
    "typescript": "6.0.3",
    "typescript-next": "npm:typescript@7.0.2",
    "vite": "8.1.4",
    "vite-plus": "^0.2.4",
    "vitest": "4.1.10"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead",
    "not ie 11"
  ],
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
